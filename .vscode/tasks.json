{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Centinela Sync Daemon",
            "type": "shell",
            "command": "powershell.exe",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\Sync-Repository.ps1"
            ],
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "centinela-ops"
            },
            "isBackground": true
        }
    ]
}